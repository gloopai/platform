{
  "info": {
    "name": "Pay Platform - Merchant Console",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "商户后台 `/v1/merchant/*`。`base_url` 必须是 **MerchantServer** 端口（见 gateway-api.yaml）。\n\n与 `backend/deploy/sql/seed_demo.sql` 演示账号一致。\n\nRegenerated by scripts/postman/generate-postman.mjs"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Merchant Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{merchant_email}}\",\n  \"password\": \"{{merchant_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/merchant/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "merchant",
                "login"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "var json = {}; try { json = pm.response.json(); } catch (e) {}",
                  "if (json && json.token) { pm.collectionVariables.set('merchant_token', json.token); pm.environment.set('merchant_token', json.token); }",
                  "if (json && json.merchant_id) { pm.collectionVariables.set('merchant_id', json.merchant_id); pm.environment.set('merchant_id', json.merchant_id); }",
                  "if (json && json.app_id) { pm.collectionVariables.set('app_id', json.app_id); pm.environment.set('app_id', json.app_id); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Merchant Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Merchant-Token",
                "value": "{{merchant_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/merchant/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "merchant",
                "logout"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Merchant-Token",
                "value": "{{merchant_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"{{old_password}}\",\n  \"new_password\": \"{{new_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/merchant/password/change",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "merchant",
                "password",
                "change"
              ]
            }
          },
          "response": []
        }
      ]
    },
