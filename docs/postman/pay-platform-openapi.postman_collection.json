{
  "info": {
    "name": "Pay Platform - Open API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "开放接口（验签 MD5）。`base_url` 必须是 **OpenAPIServer**。\n\nCollection Pre-request 会为 JSON POST / GET query 注入 `app_id`、`timestamp`、`nonce`、`sign`（与 gateway `Md5Sign` 一致）。\n\n演示密钥：`app_demo` / `demo_secret`，商户 `m_demo`（见 seed_demo.sql）。\n\nRegenerated by scripts/postman/generate-postman.mjs"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const CryptoJS = require('crypto-js');",
          "function md5SignParams(obj, secret) {",
          "  const flat = {};",
          "  for (const k of Object.keys(obj)) {",
          "    const lk = k.toLowerCase();",
          "    if (lk === 'sign') continue;",
          "    let v = obj[k];",
          "    if (v === undefined || v === null) continue;",
          "    if (typeof v === 'object') continue;",
          "    v = String(v);",
          "    if (v === '') continue;",
          "    flat[lk] = v;",
          "  }",
          "  const keys = Object.keys(flat).sort();",
          "  let raw = keys.map(k => k + '=' + flat[k]).join('&');",
          "  if (raw) raw += '&';",
          "  raw += 'key=' + secret;",
          "  return CryptoJS.MD5(raw).toString();",
          "}",
          "(function () {",
          "  const secret = pm.collectionVariables.get('openapi_api_secret');",
          "  const appId = pm.collectionVariables.get('openapi_app_id');",
          "  if (!secret || !appId) return;",
          "  const pathStr = (pm.request.url.path || []).join('/');",
          "  if (!pathStr.includes('v1/payin') && !pathStr.includes('v1/payout') && !pathStr.includes('v1/merchant/balance')) return;",
          "  const ts = Math.floor(Date.now() / 1000);",
          "  const nonce = (Date.now().toString(36) + Math.random().toString(36).slice(2, 14)).slice(0, 24);",
          "  const method = pm.request.method;",
          "  if (method === 'POST' || method === 'PUT') {",
          "    const ct = (pm.request.headers.get('Content-Type') || '');",
          "    if (ct.indexOf('application/json') === -1) return;",
          "    const rawBody = pm.request.body && pm.request.body.raw;",
          "    if (!rawBody) return;",
          "    let body;",
          "    try { body = JSON.parse(rawBody); } catch (e) { return; }",
          "    body.app_id = appId;",
          "    body.timestamp = ts;",
          "    body.nonce = nonce;",
          "    delete body.sign;",
          "    body.sign = md5SignParams(body, secret);",
          "    pm.request.body.update(JSON.stringify(body));",
          "    return;",
          "  }",
          "  if (method === 'GET') {",
          "    const params = {};",
          "    pm.request.url.query.each(function (q) {",
          "      if (q.disabled) return;",
          "      params[String(q.key).toLowerCase()] = pm.variables.replaceIn(String(q.value || ''));",
          "    });",
          "    params.app_id = appId;",
          "    params.timestamp = String(ts);",
          "    params.nonce = nonce;",
          "    delete params.sign;",
          "    const sign = md5SignParams(params, secret);",
          "    if (pm.request.url.query && pm.request.url.query.clear) {",
          "      pm.request.url.query.clear();",
          "    } else {",
          "      const qc = pm.request.url.query;",
          "      while (qc && qc.count && qc.count() > 0) { qc.remove(qc.idx(0)); }",
          "    }",
          "    Object.keys(params).sort().forEach(function (k) {",
          "      pm.request.url.query.add({ key: k, value: params[k] });",
          "    });",
          "    pm.request.url.query.add({ key: 'sign', value: sign });",
          "  }",
          "})();"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
        }
      ]
    },
