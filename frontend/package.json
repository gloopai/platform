{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:portal",
    "build": "npm run build:apps",
    "dev:portal": "npm --workspace @pay/portal run dev",
    "dev:checkout": "npm --workspace @pay/checkout run dev",
    "dev:merchant": "npm --workspace @pay/merchant run dev",
    "dev:admin": "npm --workspace @pay/admin run dev",
    "build:apps": "npm -ws --if-present run build"
  },
  "dependencies": {
    "blueimp-md5": "^2.19.0",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/blueimp-md5": "^2.18.2",
    "@types/node": "^20.14.10",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.27",
    "daisyui": "^5.5.19",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^5.4.19",
    "vue-tsc": "^3.2.5"
  }
}
